NEXT_PUBLIC_WS_URL=ws://localhost:8000

MODBUS_DEVICES_PATH=/app/devices/modbus
OPCUA_DEVICES_PATH=/app/devices/opcua
BACNET_DEVICES_PATH=/app/devices/bacnet
DNP3_DEVICES_PATH=/app/devices/dnp3
ETHERNET_IP_DEVICES_PATH=/app/devices/ethernet_ip
SNMP_DEVICES_PATH=/app/devices/snmp
MQTT_EXT_DEVICES_PATH=/app/devices/mqtt_ext
