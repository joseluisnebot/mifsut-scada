MOCK_DEVICES=true

MQTT_HOST=mosquitto
MQTT_PORT=1883

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=mytoken
INFLUX_ORG=scada
INFLUX_BUCKET=signals

POSTGRES_URL=postgresql://scada:scada@postgres:5432/scada

